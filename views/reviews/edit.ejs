<% layout("/layouts/boilerplate") %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-8 col-md-10">
      <div class="card shadow-sm rounded-4 p-4">
        <h5 class="fw-bold mb-3" style="color: #ff385c;">Edit Your Review</h5>
        <p class="text-muted mb-3">for <strong><%= listing.title %></strong></p>

        <form
          action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=PUT"
          method="POST"
          novalidate
          class="needs-validation"
        >
          <div class="mb-3">
            <label class="form-label fw-semibold">Rating</label>
            <fieldset class="starability-slot">
              <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="0" aria-label="No rating." />
              <input type="radio" id="first-rate1" name="review[rating]" value="1" <%= review.rating === 1 ? "checked" : "" %> />
              <label for="first-rate1" title="Terrible">1 star</label>
              <input type="radio" id="first-rate2" name="review[rating]" value="2" <%= review.rating === 2 ? "checked" : "" %> />
              <label for="first-rate2" title="Not good">2 stars</label>
              <input type="radio" id="first-rate3" name="review[rating]" value="3" <%= review.rating === 3 ? "checked" : "" %> />
              <label for="first-rate3" title="Average">3 stars</label>
              <input type="radio" id="first-rate4" name="review[rating]" value="4" <%= review.rating === 4 ? "checked" : "" %> />
              <label for="first-rate4" title="Very good">4 stars</label>
              <input type="radio" id="first-rate5" name="review[rating]" value="5" <%= review.rating === 5 ? "checked" : "" %> />
              <label for="first-rate5" title="Amazing">5 stars</label>
            </fieldset>
          </div>

          <div class="mb-3">
            <label for="comment" class="form-label fw-semibold">Comments</label>
            <textarea
              name="review[comment]"
              id="comment"
              cols="30"
              rows="4"
              class="form-control rounded-3 shadow-sm"
              required
            ><%= review.comment %></textarea>
            <div class="invalid-feedback">Please enter a comment</div>
          </div>

          <button type="submit" class="btn btn-dark rounded-pill px-4 py-2 me-2">Update</button>
          <a href="/listings/<%= listing._id %>" class="btn btn-outline-secondary rounded-pill px-4 py-2">Cancel</a>
        </form>
      </div>
    </div>
  </div>
</div>
